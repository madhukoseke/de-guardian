# Copy to .env for local dev (the app also runs with none of these set).

# Render Postgres connection string. Leave unset locally to use the in-memory store.
# DATABASE_URL=postgresql://user:pass@host:5432/pipeline_runs

# The SuperPlane Canvas webhook trigger URL. On a failed run the service POSTs
# the incident payload here to start the agent investigation.
# SUPERPLANE_WEBHOOK_URL=https://<your-superplane-host>/api/v1/webhooks/<id>

# Public URL of this service (Render web service). Used in incident payload for
# Canvas HTTP remediation: context.heal_url
# SERVICE_BASE_URL=https://bash-script-funeral.onrender.com

# For the scheduled cron run, arm a failure mode (healthy | schema_drift |
# null_violation | upstream_timeout | type_mismatch | duplicate_pk).
# PIPELINE_MODE=healthy
